{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "RUN: DEVELOPMENT",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define=ENV_NAME=DEV",
        "--dart-define=BASE_URL=https://fakestoreapi.com",
        "--dart-define=SHOW_DEBUG_BANNER=true"
      ]
    },
    {
      "name": "RUN: PRODUCTION",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "release",
      "toolArgs": [
        "--dart-define=ENV_NAME=PRODUCTION",
        "--dart-define=BASE_URL=https://fakestoreapi.com",
        "--dart-define=SHOW_DEBUG_BANNER=false"
      ]
    }
  ]
}